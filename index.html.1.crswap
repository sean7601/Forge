        <div class="tab-content" id="myTabContent">

            <div class="tab-pane fade show active" id="editor-container" role="tabpanel">
                <div class="row p-0 m-0">
                    <div id="sidebar" class="col-3 m-0 p-2">
                        <h5 style="color:#dce3eb">Browser IDE</h5>
                        <button class="btn btn-primary btn-block mb-2" id="load-directory-btn"
                            data-action="load-directory">Open App Folder</button>
                        <!-- Quick actions replace Open App Folder after project loads -->
                        <div id="editor-quick-actions" class="mb-2" style="display:none;">
                            <div class="d-flex align-items-stretch" style="gap: 0.5rem;">
                                <div class="dropdown flex-grow-1" id="open-ai-dropdown">
                                    <button class="btn btn-success w-100 dropdown-toggle" type="button" id="open-ai-btn"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                        AI Services
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="open-ai-btn"
                                        style="width:100%;">
                                        <li><a class="dropdown-item" href="#" data-ai-action="athena">Prometheus (In-App)</a>
                                        </li>
                                        <li><a class="dropdown-item" href="#"
                                                data-ai-url="https://genai.mil">GenAI.mil</a>
                                        </li>
                                        <li><a class="dropdown-item" href="#"
                                                data-ai-url="https://chat.capra.flankspeed.us.navy.mil">Capra
                                                (NAVAIR)</a>
                                        </li>
                                        <li><a class="dropdown-item" href="#"
                                                data-ai-url="https://aistudio.google.com/prompts/new_chat">Google AI
                                                Studio
                                                (Non-CUI)</a>
                                        </li>
                                    </ul>
                                </div>
                                <button class="btn btn-warning flex-shrink-0" id="ship-now-btn" type="button"
                                    title="Compile and download with recommended secure defaults">
                                    Ship
                                </button>
                            </div>
                        </div>
                        <div class="file-operations" id="file-operations" style="display:none;">
                            <button class="btn btn-success btn-sm d-none" data-action="create-root-file"
                                title="Create new file in root directory">
                                + New File
                            </button>
                        </div>
                        <!-- Global Search UI -->
                        <div id="search-box" class="mb-2" style="display:none;">
                            <div class="input-group input-group-sm mb-1">
                                <input id="global-search-input" type="text" class="form-control"
                                    placeholder="Search code (Enter)">
                                <div class="input-group-append">
                                    <button class="btn btn-secondary" id="global-search-btn" title="Search">Go</button>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small id="search-summary" style="color:#7b8a9c; display:none;"></small>
                                <small id="search-clear"
                                    style="color:#60a5fa; cursor:pointer; display:none;">clear</small>
                            </div>
                        </div>
                        <div id="search-results"
                            style="max-height:35vh; overflow:auto; font-size: 0.75rem; line-height:1.2; display:none; border:1px solid #232e3b; border-radius:8px; padding:4px; background:#141c26;">
                        </div>
                        <div id="file-tree"></div>
                    </div>
                    <div class="col-9 m-0 p-0">
                        <div id="editor-header" class="d-flex align-items-center px-2 py-1 bg-dark border-bottom"
                            style="border-color: #232e3b !important; min-height: 42px; display: none;">
                            <!-- Save controls will be injected here by loadFolder.js -->
                        </div>
                        <div id="ai-review-bar">
                            <span id="ai-review-label"></span>
                            <div style="flex:1"></div>
                            <button class="btn btn-sm" id="ai-review-open-btn" onclick="openAIPendingDiff()">View Diff</button>
                            <button class="btn btn-sm btn-success" id="ai-review-accept-all-btn" onclick="acceptAllAIPendingFromIDE()">Accept All</button>
                            <button class="btn btn-sm btn-success" id="ai-review-accept-btn" onclick="approveAIPendingFromIDE()">Accept Here</button>
                            <button class="btn btn-sm" id="ai-review-reject-btn" onclick="rejectAIPendingFromIDE()">Reject Here</button>
                        </div>
                        <div id="ai-diff-inline"></div>
